---
import Image from 'astro/components/Image.astro';
import H1Specs from './H1specs.astro';
import MarkdownIt from 'markdown-it';
const md = new MarkdownIt({
  html: true, // Permite HTML en el fuente
  linkify: true, // Autoconvierte URL en enlaces
  typographer: true, // Mejora tipográfica
  breaks: false, // Convierte '\n' en <br>
});

const props = Astro.props;
// console.log('CABECERA PROPS', props);
---

<div class="flex flex-col items-center lg:w-full overflow-hidden opacity-85">
  <H1Specs>{props.h1}</H1Specs>
  <div class="flex flex-col md:flex-row items-center mt-4">
    <div class="md:w-1/3 flex flex-row sm:flex-col items-center">
      <Image
        src={props.slugImagen}
        alt={props.altPrincipal}
        width={256}
        height={256}
        class="object-fit md:object-contain"
        loading="eager"
      />
    </div>
    <div
      class="flex flex-col items-left mx-auto md:w-2/3 sm:px-8 text-left text-base sm:text-lg"
    >
      {
        //comprueba si props.textoLimpio es de tipo array o string

        props.textolimpio.length > 0 ? (
          props.textolimpio.map((parrafo: any) => (
            <>
              <p class="py-2 sm:p-2" set:html={md.render(parrafo)} />
            </>
          ))
        ) : (
          <p class="py-2 sm:p-2" set:html={md.render(props.textolimpio)} />
        )
      }
      {
        props.referenciaLocal === 1 && (
          <p class="py-4">
            Ofrecemos{' '}
            <a href={props.enlaceLocal} class="text-blue-700">
              {`${props.h1} en Sevilla`}
            </a>{' '}
            y en toda España. Confía en nosotros para solucionar cualquier
            problema de tu dispositivo.
          </p>
        )
      }
    </div>
  </div>
</div>
