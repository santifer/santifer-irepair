---
import Image from 'astro/components/Image.astro';
import H1Specs from './H1specs.astro';

// Define las propiedades que esperas recibir en tu componente
interface CardProps {
  slugImagen: string;
  altTexto: string;
  h1: string;
  textoH1: string;
  width?: number; // Hacemos que width sea opcional
  height?: number; // Hacemos que height sea opcional
}

const {
  slugImagen,
  altTexto,
  h1,
  textoH1,
  width = 384,
  height = 256,
} = Astro.props as CardProps;
---

<div class="flex flex-row shadow-lg p-8 w-full">
  <Image src={slugImagen} alt={altTexto} width={width} height={height} />
  <div class="flex flex-col items-center text-center mx-auto w-full px-8">
    <H1Specs>{h1}</H1Specs>
    <div class="mt-8 w-2/3">{textoH1}</div>
  </div>
</div>
