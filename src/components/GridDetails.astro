---
import { Image } from 'astro:assets';
import type { IDetails } from '../lib/schema';

const details = Astro.props.details as IDetails[];
const idAnexo = Astro.props.idAnexo as string;
const stringPrincipal = Astro.props.stringPrincipal as string;

const {
  modo = '',
  modoEnlace = '',
  modoModelo = '',
  modeloImg = '',
  citaDiag = '',
  urlPresupuesto = '',
  modoMarca = '',
  marcaImg = '',
  anchor = '',
  ocultarMicrocopy = false,
  mostrarPrecio = '',
} = Astro.props;

const indexableDetails = details.filter((detail: IDetails) => detail.indexable);
const nonIndexableDetails = details.filter(
  (detail: IDetails) => !detail.indexable
);
---

<div
  class={`w-full grid grid-cols-1 ${
    !modoEnlace
      ? 'sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4'
      : 'sm:grid-cols-2'
  } gap-2 sm:gap-4 p-2 sm:p-4 justify-center`}
  id={`grid-container-${idAnexo}`}
>
  {
    /*
      1. Tarjeta de Diagnóstico (si procede)
      - Ya estaba en verde; lo mantenemos tal cual.
    */
  }
  {
    modoModelo !== '' && modeloImg && (
      <button
        id="diag-modelo"
        data-url={citaDiag}
        data-modal="sharedModal"
        data-type="modal"
        class="button border-2 h-max-10 border-green-200 hover:border-green-400 w-full card group bg-white flex flex-row sm:flex-col items-center justify-center overflow-hidden rounded-3xl shadow-lg hover:shadow-xl transition-shadow duration-300"
      >
        <Image
          src={modeloImg}
          alt={`Diagnóstico de ${modeloImg}`}
          width={384}
          height={256}
          title={`Diagnóstico de ${modoModelo}`}
          class="w-1/2 h-36 sm:w-[384px] max-h-[256px] object-contain p-2 transition-transform duration-300 ease-in-out group-hover:scale-105 lg:h-[157px]"
          loading="lazy"
        />
        <div class="relative bg-gradient-to-r from-green-50 to-white p-4 flex flex-col items-center justify-center sm:items-center sm:justify-around w-full h-full text-center group-hover:bg-gradient-to-r group-hover:from-green-100 group-hover:to-green-50">
          <h3 class="text-lg font-light">
            <span class="text-lg sm:text-xl font-semibold text-blue-600">
              Diagnóstico:
            </span>
            <br />
            ¿Qué le ocurre a mi{' '}
            <span class="text-lg sm:text-xl font-semibold text-blue-600">
              {modoModelo}
            </span>
            ?
          </h3>
          <p class="text-sm text-gray-700 mt-2">
            ¿No enciende o no sabes qué le pasa? Solicita un diagnóstico y lo
            revisamos de arriba a abajo.
          </p>
        </div>
      </button>
    )
  }

  {
    /*
      2. Reparaciones (Indexables)
      - Sustituimos el color azul/naranja por verde en borde y fondo hover
    */
  }
  {
    indexableDetails.map((detail: any) => {
      const saltofinal = modo === 'alternativo' ? detail.salto2 : detail.salto;
      const textoDestacadoFinal =
        modo === 'alternativo' ? detail.textoDestacado2 : detail.textoDestacado;
      const replacedH1 = detail.h1.replace(
        textoDestacadoFinal,
        'PLACEHOLDERTEXT'
      );
      const highlightIndex = replacedH1.indexOf('PLACEHOLDERTEXT');

      let firstPart, secondPart;
      if (saltofinal === 'después' || saltofinal === 'ambos') {
        secondPart = replacedH1.slice(
          highlightIndex + 'PLACEHOLDERTEXT'.length
        );
      } else {
        secondPart = '';
      }

      if (saltofinal === 'antes' || saltofinal === 'ambos') {
        firstPart = replacedH1.slice(0, highlightIndex);
      } else {
        firstPart = replacedH1.slice(
          0,
          highlightIndex + 'PLACEHOLDERTEXT'.length
        );
      }

      const highlightedText = (
        <span class="text-lg sm:text-xl font-semibold text-blue-600">
          {textoDestacadoFinal}
        </span>
      );

      const destinationUrl = anchor
        ? detail.slugTotal + anchor
        : detail.slugTotal;

      const microcopy =
        !ocultarMicrocopy && detail.microcopy ? detail.microcopy : '';

      let cadenaPrecio = '';
      if (mostrarPrecio.startsWith('desde') && detail.precioMinCard) {
        cadenaPrecio = `Desde ${detail.precioMinCard}`;
      }
      if (mostrarPrecio === 'desdeHasta' && detail.precioMaxCard) {
        cadenaPrecio = `${cadenaPrecio} hasta ${detail.precioMaxCard}`;
      }
      if (mostrarPrecio === 'exacto' && detail.precioMinCard) {
        cadenaPrecio = `${detail.precioMinCard}`;
        if (detail.precioMaxCard) {
          cadenaPrecio = `Desde ${detail.precioMinCard} hasta ${detail.precioMaxCard}`;
        }
      }

      return (
        <div
          role="link"
          tabindex="0"
          style="cursor: pointer;"
          onclick={`window.location.href='${destinationUrl}'`}
          onkeydown={`if (event.key === 'Enter' || event.key === ' ') {
          window.location.href='${destinationUrl}'
        }`}
          class="border-2 border-green-200 hover:border-green-400 w-full card group bg-white flex flex-row sm:flex-col items-center justify-center overflow-hidden rounded-3xl shadow-lg hover:shadow-xl transition-shadow duration-300"
        >
          <Image
            src={detail.slugImagen}
            alt={`Imagen de ${detail.h1}`}
            width={384}
            height={256}
            title={detail.h1}
            class={`w-1/2 h-auto sm:w-auto max-h-[256px] object-contain p-2 transition-transform duration-300 ease-in-out group-hover:scale-105`}
            loading="lazy"
          />
          <div class="bg-gradient-to-r from-green-50 to-white p-4 flex flex-col items-center justify-center sm:items-center sm:justify-between w-full h-full text-center group-hover:bg-gradient-to-r group-hover:from-green-100 group-hover:to-green-50">
            <h3 class="text-lg font-light my-3 mx-3">
              <a href={destinationUrl}>
                {firstPart.replace('PLACEHOLDERTEXT', '')}
                {highlightedText}
                {secondPart}
              </a>
            </h3>

            <p class="text-sm text-gray-700 mt-2">{microcopy}</p>
            {cadenaPrecio && mostrarPrecio !== 'exacto' && (
              <p class="text-base tracking-tighter text-blue-600 mt-2">
                {cadenaPrecio}
              </p>
            )}
            {cadenaPrecio && mostrarPrecio === 'exacto' && (
              <p class="text-base tracking-tighter  text-blue-600 mt-2">
                {cadenaPrecio}{' '}
                <span class="underline font-semibold group-hover:text-green-600">
                  {' '}
                  ver detalles
                </span>
              </p>
            )}
          </div>
          {/* {mostrarPrecio === 'exacto' && (
            <div class="border-2 border-green-700 p-4 hover:border-green-700 w-full card group bg-green-600 flex flex-row sm:flex-col items-center justify-center overflow-hidden rounded-b-3xl shadow-lg hover:shadow-xl transition-shadow duration-300">

              <p class="text-xl text-white  font-bold mt-2">
                Pide tu cita
              </p>
            </div>
            )} */}
        </div>
      );
    })
  }

  {
    /*
      3. Reparaciones (No Indexables) -> <button> en vez de <a>
      - También unificamos el estilo en verde
    */
  }
  {
    nonIndexableDetails.map((detail: any) => {
      const saltofinal = modo === 'alternativo' ? detail.salto2 : detail.salto;
      const textoDestacadoFinal =
        modo === 'alternativo' ? detail.textoDestacado2 : detail.textoDestacado;
      const replacedH1 = detail.h1.replace(
        textoDestacadoFinal,
        'PLACEHOLDERTEXT'
      );
      const highlightIndex = replacedH1.indexOf('PLACEHOLDERTEXT');

      let firstPart, secondPart, highlightedText;

      if (saltofinal === 'antes' || saltofinal === 'ambos') {
        firstPart = replacedH1.slice(0, highlightIndex);
      } else {
        firstPart = replacedH1.slice(
          0,
          highlightIndex + 'PLACEHOLDERTEXT'.length
        );
      }

      if (saltofinal === 'después' || saltofinal === 'ambos') {
        secondPart = replacedH1.slice(
          highlightIndex + 'PLACEHOLDERTEXT'.length
        );
        highlightedText = (
          <span class="text-lg sm:text-xl font-semibold text-blue-600">
            {textoDestacadoFinal}
          </span>
        );
      } else {
        secondPart = '';
        highlightedText = (
          <>
            <br />
            <span class="text-lg sm:text-xl font-semibold text-blue-600">
              {textoDestacadoFinal}
            </span>
          </>
        );
      }

      const destinationUrl = anchor
        ? detail.slugTotal + anchor
        : detail.slugTotal;

      const microcopy =
        !ocultarMicrocopy && detail.microcopy ? detail.microcopy : '';

      let cadenaPrecio = '';
      if (mostrarPrecio.startsWith('desde') && detail.precioMinCard) {
        cadenaPrecio = `Desde ${detail.precioMinCard}`;
      }
      if (mostrarPrecio === 'desdeHasta' && detail.precioMaxCard) {
        cadenaPrecio = `${cadenaPrecio} hasta ${detail.precioMaxCard}`;
      }
      if (mostrarPrecio === 'exacto' && detail.precioMinCard) {
        cadenaPrecio = `${detail.precioMinCard}`;
        if (detail.precioMaxCard) {
          cadenaPrecio = `Desde ${detail.precioMinCard} hasta ${detail.precioMaxCard}`;
        }
      }

      const splittedSlug = detail.slugTotal.replace(/^\//, '').split('/');
      return (
        <div
          role="link"
          tabindex="0"
          style="cursor: pointer;"
          onclick={`joinSegmentsAndRedirect(${JSON.stringify(splittedSlug)}, '${anchor}')`}
          onkeydown={`if (event.key === 'Enter' || event.key === ' ') {
    joinSegmentsAndRedirect(${JSON.stringify(splittedSlug)}, '${anchor}');
  }`}
          onkeydown={`if (event.key === 'Enter' || event.key === ' ') {
          window.location.href='${destinationUrl}'
        }`}
          class="border-2 border-green-200 hover:border-green-400 w-full card group bg-white flex flex-row sm:flex-col items-center justify-center overflow-hidden rounded-3xl shadow-lg hover:shadow-xl transition-shadow duration-300"
        >
          <Image
            src={detail.slugImagen}
            alt={`Imagen de ${detail.h1}`}
            width={384}
            height={256}
            title={detail.h1}
            class={`w-1/2 h-auto sm:w-auto max-h-[256px] object-contain p-2 transition-transform duration-300 ease-in-out group-hover:scale-105`}
            loading="lazy"
          />
          <div class="bg-gradient-to-r from-green-50 to-white p-4 flex flex-col items-center justify-center sm:items-center sm:justify-between w-full h-full text-center group-hover:bg-gradient-to-r group-hover:from-green-100 group-hover:to-green-50">
            <h3 class="text-lg font-light my-3 mx-3">
              {firstPart.replace('PLACEHOLDERTEXT', '')}
              {highlightedText}
              {secondPart}
            </h3>
            {microcopy && <p class="text-sm text-gray-700 mt-2">{microcopy}</p>}
            {cadenaPrecio && mostrarPrecio !== 'exacto' && (
              <p class="text-base tracking-tighter  text-blue-600 mt-2">
                {cadenaPrecio}
              </p>
            )}
            {cadenaPrecio && mostrarPrecio === 'exacto' && (
              <p class="text-base tracking-tighter  text-blue-600 mt-2">
                {cadenaPrecio}{' '}
                <span class="underline font-semibold group-hover:text-green-600">
                  {' '}
                  ver detalles
                </span>
              </p>
            )}
          </div>
        </div>
      );
    })
  }

  {
    /*
      3. Tarjetas de Presupuesto (final)
      - Cambiamos naranjas a verdes también
    */
  }
  {
    modoModelo !== '' && modeloImg && (
      <button
        id="presupuesto-modelo"
        data-url={urlPresupuesto}
        data-modal="sharedModal"
        data-type="modal"
        class="button border-2 border-green-200 hover:border-green-400 w-full card group bg-white flex flex-row sm:flex-col items-center justify-center overflow-hidden rounded-3xl shadow-lg hover:shadow-xl transition-shadow duration-300"
      >
        <Image
          src={modeloImg}
          alt={`Imagen desenfocada de ${modoModelo}, invitando a pedir presupuesto`}
          width={384}
          height={256}
          title={`Presupuesto de ${modoModelo}`}
          class="w-1/2 h-36 sm:w-[384px] max-h-[256px] object-contain p-2 transition-transform duration-300 ease-in-out group-hover:scale-105 lg:h-[157px]"
          loading="lazy"
        />
        <div class="relative bg-gradient-to-r from-green-50 to-white p-4 flex flex-col items-center justify-center sm:items-center sm:justify-around w-full h-full text-center group-hover:bg-gradient-to-r group-hover:from-green-100 group-hover:to-green-50">
          <h3 class="text-lg font-light">
            <span class="text-lg sm:text-xl font-semibold text-blue-600">
              Presupuesto:
            </span>
            <br />
            Otra avería de <br />
            <span class="text-lg sm:text-xl font-semibold text-blue-600">
              {modoModelo}
            </span>
          </h3>
          <p class="text-sm text-gray-700 mt-2">
            ¿Tu avería no aparece aquí? Solicita presupuesto y te damos la
            solución que necesitas.
          </p>
        </div>
      </button>
    )
  }

  {
    modoMarca !== '' && marcaImg && (
      <button
        id="presupuesto-marca"
        data-url={urlPresupuesto}
        data-modal="sharedModal"
        data-type="modal"
        class="button border-2 border-green-200 hover:border-green-400 w-full card group bg-white flex flex-row sm:flex-col items-center justify-center overflow-hidden rounded-3xl shadow-lg hover:shadow-xl transition-shadow duration-300"
      >
        <Image
          src={marcaImg}
          alt={`Imagen desenfocada de ${modoMarca}, invitando a pedir presupuesto`}
          width={384}
          height={256}
          title={`Presupuesto de ${modoMarca}`}
          class="w-1/2 h-auto sm:w-[384px] max-h-[256px] object-contain p-2 transition-transform duration-300 ease-in-out group-hover:scale-105"
          loading="lazy"
        />
        <div class="relative bg-gradient-to-r from-green-50 to-white p-4 flex flex-col items-center justify-center sm:items-center sm:justify-start w-full h-full text-center group-hover:bg-gradient-to-r group-hover:from-green-100 group-hover:to-green-50">
          <h3 class="text-lg font-light">
            <span class="text-lg sm:text-xl font-semibold text-blue-600">
              Presupuesto:
            </span>
            <br />
            No aparece mi <br />
            <span class="text-lg sm:text-xl font-semibold text-blue-600">
              {modoMarca}
            </span>
          </h3>
        </div>
      </button>
    )
  }
</div>
