---
import Image from 'astro/components/Image.astro';
import H1Specs from './H1specs.astro';
import MarkdownIt from 'markdown-it';
const md = new MarkdownIt({
  html: true, // Permite HTML en el fuente
  linkify: true, // Autoconvierte URL en enlaces
  typographer: true, // Mejora tipográfica
  breaks: false, // Convierte '\n' en <br>
});

const props = Astro.props;
// console.log('CABECERA PROPS', props);

const adaptedWidth = props.cabeceraReparacion && props.cabeceraReparacion === 'true' ? '384' : '256';



const getTiempoRep = (slug: string) => {
  if (props.paramTipo === 'movil' || props.paramTipo === 'teléfono') return "45 min";
  if (props.paramTipo === 'tablet') return "1 hora";
  if (props.paramTipo === 'smartwatch') return "1 a 2 horas";
  return "1 hora"; // default value
};

const tiempoRep = props.slugImagen ? getTiempoRep(props.slugImagen) : "1 hora";
// console.log(props)

// const badgeColor = '#c2410c' (orange-800)
const badgeColor = '#F97316'
const textColor = 'text-orange-600'


// Variables de clases para estilos
const containerBadgesClass = `
  mt-4
  md:w-fit
  md:mx-auto
  md:my-2
  grid
  grid-cols-3   
  md:grid-cols-1 
  lg:grid-cols-3 
  gap-2
  md:gap-0
  bg-white
`;

const singleBadgeClass = `
  flex
  flex-col
  sm:flex-row
  items-center    
  justify-center  
  md:justify-start 
  lg:flex-col
  p-4
  md:p-1
`;

const badgeTextClass = `
  ml-2
  mt-1
  sm:mt-0
  text-sm
  ${textColor}
  text-center
  md:text-left
  lg:text-center
  lg:mt-2
  lg:ml-0
`;
---

<div
  class=" flex flex-col items-center lg:w-full rounded-b-3xl sm:rounded-3xl shadow-md border-2 border-stone-200 overflow-hidden  "
>
  <H1Specs>{props.h1}</H1Specs>
  <div
  class="flex flex-col md:flex-row-reverse items-stretch md:items-stretch  "
>
<div
  class="
    md:w-1/3 
    flex 
    flex-col
    items-center
    p-1
    md:justify-between
    bg-white
    md:border-l-2
    md:border-stone-200
    min-h-[400px]
    sm:min-h-[360px]
  "
>
      <Image
        src={props.slugImagen}
        alt={props.altPrincipal}
        width={adaptedWidth}
        height={256}
        class="object-fit md:object-contain"
        loading="eager"
      />
{props.microcopy && (() => {
  // Separamos y limpiamos los modelos
  const models = props.microcopy.split(',').map((model: string) => model.trim());
  // Determinamos si es plural o singular
  const label = models.length > 1 ? 'Números de modelo:' : 'Número de modelo:';
  // Usamos dos líneas si hay 4 o más modelos
  const useTwoLines = models.length > 3;
  
  if (useTwoLines) {
    return (
      <>
        <p class="text-center text-sm text-stone-800">{label}</p>
        <p class="text-center text-sm text-stone-800 font-semibold">{props.microcopy}</p>
      </>
    );
  } else {
    return (
      <p class="text-center text-sm text-stone-800 ">
        {label} <span class="font-semibold">{props.microcopy}</span>
      </p>
    );
  }
})()}
     <!-- Contenedor global de badges -->
      
    <div class={containerBadgesClass}>
      <!-- Badge 1: en 1 hora reparado -->
      <div class={singleBadgeClass}>
<svg
  width="50"
  height="50"
  viewBox="0 0 24 24"
  xmlns="http://www.w3.org/2000/svg"
>
  <!-- Círculo principal: borde naranja, fondo blanco -->
  <circle
    cx="12"
    cy="12"
    r="8.5"
    fill="#FFFFFF"
    stroke={badgeColor}
    stroke-width="2"
  />

  <!-- Corona inclinada a 45° en la parte superior-derecha -->
  <rect
    x="16.5"
    y="2"
    width="3"
    height="4"
    fill={badgeColor}
    rx="1"
    transform="rotate(45 18 4)"
  />

  <!-- Aguja con la punta hacia afuera (apex en el borde) y base en el centro -->
  <!-- Comenzamos en el centro (12,12), subimos a (11,11), luego la punta en (12,5), y volvemos a (13,11) para cerrar el triángulo -->
  <path
    d="M12 12 L11 11 L12 5 L13 11 Z"
    fill={badgeColor}
  />
</svg>
        <span class={badgeTextClass}><span class="font-bold">{tiempoRep}</span> de Reparación</span>
      </div>

      <!-- Badge 2: 6 meses de garantía -->
      <div class={singleBadgeClass}>
        <svg
          width="50"
          height="50"
          viewBox="0 0 24 24"
          xmlns="http://www.w3.org/2000/svg"
        >
          <!-- Escudo naranja -->
          <path
            d="M12 2l7 4v5c0 7-4 9-7 10-3-1-7-3-7-10V6l7-4z"
            fill={badgeColor}
          />
          <!-- Check en blanco -->
          <path
            d="M9 12l2 2 4-4"
            fill="none"
            stroke="#FFFFFF"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
        <span class={badgeTextClass}><span class="font-semibold">6 Meses</span> de Garantía</span>
      </div>

      <!-- Badge 3: 15 años de experiencia -->
      <div class={singleBadgeClass}>
        <svg
          width="50"
          height="50"
          viewBox="0 0 24 24"
          preserveAspectRatio="xMidYMid meet"
          xmlns="http://www.w3.org/2000/svg"
        >
          <!-- Cinta detrás (blanco) con borde naranja -->
          <polyline
            points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"
            fill="#FFFFFF"
            stroke={badgeColor}
            stroke-width="1.5"
            stroke-linejoin="round"
          />
          <!-- Círculo naranja encima -->
          <circle
            cx="12"
            cy="8"
            r="7"
            fill={badgeColor}
          />
        </svg>
        <span class={badgeTextClass}><span class="font-semibold">15 años</span> de Experiencia</span>
      </div>
    </div>
    </div>
    <div
      class="
    flex-1
    bg-stone-50/80
    px-4
    sm:px-8
    flex
    flex-col
    justify-between
    border-stone-200
    pt-4
    pb-6
  "
  >
      {
        //comprueba si props.textoLimpio es de tipo array o string

        props.textolimpio.length > 0 ? (
          props.textolimpio.map((parrafo: any) => (
            <>
              <p class="py-2 sm:pl-2" set:html={md.render(parrafo)} />
            </>
          ))
        ) : (
          <p class="py-2 sm:pl-2" set:html={md.render(props.textolimpio)} />
        )
      }
      <slot />
    </div>
  </div>
</div>
