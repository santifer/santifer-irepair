---
type Props = {
  destino: string;
  texto: string;
  tipo?: 'general' | 'reseñas' | 'ejemplos'; // Define tipos de botones
};

const { destino, texto, tipo = 'general' } = Astro.props;

// Mapear estilos por tipo
const estiloTipo = {
  general:
    'border-green-600 bg-green-600 text-white hover:border-green-900 hover:bg-green-100 hover:text-black shadow-lg',
  reseñas:
    'border-blue-400 bg-blue-200 text-[#333333] hover:border-blue-700 hover:bg-blue-800 hover:text-white shadow-lg',
  ejemplos:
    'border-yellow-500 bg-yellow-300 text-[#333333] hover:border-yellow-700 hover:bg-yellow-600 hover:text-white shadow-lg',
}[tipo];
---

<a
  href={`#${destino}`}
  class={`mb-3 btn btn-dark mt-4 text-center rounded-full px-8 py-3 text-2xl font-medium ${estiloTipo}`}
>
  {texto}
</a>
