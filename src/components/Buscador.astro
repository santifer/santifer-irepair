---
import { propsToFilename } from 'astro/assets/utils';

// Recibe los props del componente padre o de la página que lo incluye
const {
  filtroTipo = '',
  filtroMarca = '',
  placeholderBuscador = '¿Qué te reparamos hoy?',
  numElementos = 5,
} = Astro.props;
---

<div class="relative z-10">
  <div
    id="resultados"
    role="listbox"
    aria-label="Resultados de búsqueda"
    class="hidden absolute w-full bg-gradient-to-br from-stone-50 to-stone-100 mt-8 pt-7 pb-3 rounded-b-2xl shadow-sm z-0 opacity-0 transition-opacity duration-500 border-4 border-stone-300"
  >
  </div>
  <div
    id="searchBox"
    class="bg-white flex items-center rounded-full w-72 border-4 border-stone-300 drop-shadow-sm sm:w-96 h-14 px-4 transition-all duration-700 animate-borderPulse"
    data-filtro-tipo={filtroTipo}
    data-filtro-marca={filtroMarca}
  >
    <input
      id="search-input"
      name="search"
      class="bg-transparent text-gray-900 text-center placeholder-gray-400 text-lg sm:text-xl font-light tracking-tight outline-none flex-grow"
      placeholder={placeholderBuscador}
      oninput="handleInput(event)"
      onfocus="handleFocus(event)"
    />
    <button id="boton-buscador" class="hidden">
      <svg
        class="text-white w-6 h-6"
        fill="#BBBBBB"
        stroke="#BBBBBB"
        viewBox="0 0 24 24"
        xmlns="http://www.w3.org/2000/svg"
        onclick="clearInput()"
      >
        <path class="secondary" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
    <svg
      id="icono-lupa"
      class="text-white w-6 h-6"
      fill="#BBBBBB"
      stroke="#BBBBBB"
      viewBox="0 0 24 24"
      xmlns="http://www.w3.org/2000/svg"
      onclick="clearInput()"
    >
      <path
        class="secondary"
        d="M16.32 14.9l1.1 1.1c.4-.02.83.13 1.14.44l3 3a1.5 1.5 0 0 1-2.12 2.12l-3-3a1.5 1.5 0 0 1-.44-1.14l-1.1-1.1a8 8 0 1 1 1.41-1.41zM10 16a6 6 0 1 0 0-12 6 6 0 0 0 0 12z"
      ></path>
    </svg>
  </div>
</div>

<script is:inline src="/scripts/searchComponent8.js"></script>

