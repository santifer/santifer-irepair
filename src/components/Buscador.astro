  async function cargarYConvertirModelos() {
    const urlModelos = '/modelos5.json';
    try {
      const response = await fetch(urlModelos);
      const modelos = await response.json();

      modelosconv = modelos.flatMap((marca: any) => [
        ...(marca.m
