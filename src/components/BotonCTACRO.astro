---
type Props = {
  destino: string;
  texto: string;
  tipo?: 'general' | 'reseñas' | 'ejemplos'; // Define tipos de botones
  subtexto?: string; // <--- Nueva prop para el microcopy
  tarifas?: boolean
};

const { destino, texto, tipo = 'general', subtexto, tarifas = false } = Astro.props;

// Mapear estilos por tipo
const estiloTipo = {
  general:
    'bg-green-600 text-white hover:bg-green-700 hover:text-gray-100 shadow-lg',
  reseñas:
    'border-blue-400 bg-blue-200 text-[#333333] hover:border-blue-700 hover:bg-blue-800 hover:text-white shadow-lg',
  ejemplos:
    'border-yellow-500 bg-yellow-300 text-[#333333] hover:border-yellow-700 hover:bg-yellow-600 hover:text-white shadow-lg',
}[tipo];
---

<div class="flex flex-col items-center">
  <button
    onclick={`document.getElementById('${destino}').scrollIntoView({ behavior: 'smooth' })`}
    class={`mb-3 btn btn-dark mt-6 text-center rounded-full px-8 py-3 text-2xl font-medium ${estiloTipo}`}
  >
    {texto}
  </button>
{
  subtexto && tarifas === true && (
    <span class="flex flex-col justify-center gap-2 md:flex-row text-sm items-center text-center">{subtexto} <a href={`#${destino}`} class="rounded-full border-2 px-3 py-2 border-green-600 text-green-600 font-semibold hover:text-green-700 hover:border-green-700">ver tarifas</a> </span> 
    
  )
}

{
  subtexto && tarifas === false && (
    <span class="block text-sm text-center">{subtexto} </span> 
    
  )
}
</div>
